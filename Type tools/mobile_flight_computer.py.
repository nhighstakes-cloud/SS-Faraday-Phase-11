def run_simulation():
    print("--- SS FARADAY: FLIGHT COMPUTER v1.1 ---")
    for i in range(1, 13):
        noise = random.uniform(-0.00000002, 0.00000002)
        if i >= 7:
            mass = 5.00000000 - 0.00000050 + noise
            event = "!! BREACH !!"
        else:
            mass = 5.00000000 + noise
            event = "CASIMIR LOAD"
        print(f"S{i:02} | {mass:.8f}g | {event}")
        time.sleep(0.3)

if __name__ == "__main__":
